# Mobile app configuration (PRD §5.2) — copy to .env and adjust.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_DEFAULT_THEME=light
EXPO_PUBLIC_PRIMARY_COLOR=#16A34A
EXPO_PUBLIC_APP_NAME=Klyron Estate
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true

# Business toggles (mirrored client-side while running on mock data)
EXPO_PUBLIC_REQUIRE_OWNER_APPROVAL=true
EXPO_PUBLIC_DEFAULT_COMMISSION_RATE=1.5
